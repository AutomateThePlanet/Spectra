# Execution state (local, transient) — includes the ephemeral console marker
# (.execution/console.json) and the local-only run console page (Spec 066). Never committed.
.execution/

# Reports (local execution reports, not source code)
/reports/

# .NET build artifacts
bin/
obj/
*.user
*.suo
*.cache
*.vs/
*.nupkg

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# NuGet
packages/

# Test results
TestResults/
coverage/

# SPECTRA lock files
.spectra.lock

# SPECTRA per-session verdict files and drop trail (scratch, not committed)
.spectra/verdicts/
.spectra/dropped-tests.json

# Node (for runner-ui)
node_modules/
dist/
.next/
