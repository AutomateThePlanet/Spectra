{
  "testimizeSettings": {
    "seed": 12345,
    "locale": "en",
    "includeBoundaryValues": true,
    "allowValidEquivalenceClasses": false,
    "allowInvalidEquivalenceClasses": true,
    "abcGenerationSettings": {
      "totalPopulationGenerations": 20,
      "mutationRate": 0.3,
      "finalPopulationSelectionRatio": 0.5,
      "eliteSelectionRatio": 0.5,
      "onlookerSelectionRatio": 0.1,
      "scoutSelectionRatio": 0.3,
      "enableOnlookerSelection": true,
      "enableScoutPhase": false,
      "enforceMutationUniqueness": true,
      "stagnationThresholdPercentage": 0.75,
      "coolingRate": 0.95,
      "allowMultipleInvalidInputs": false
    },
    "inputTypeSettings": {
      "Email": {
        "PrecisionStep": "1",
        "InvalidEquivalenceClasses": [
          "@missingusername.com",
          "missingdomain@",
          "user@.com",
          "user@domain..com"
        ]
      },
      "Phone": {
        "PrecisionStep": "1",
        "InvalidEquivalenceClasses": [
          "+123",
          "abcdefg",
          "+359888BADNUM"
        ]
      },
      "Text": {
        "PrecisionStep": "1",
        "InvalidEquivalenceClasses": [
          "<script>alert('XSS')</script>",
          "' OR 1=1 --",
          "${7*7}",
          "{{constructor.constructor('return this')()}}"
        ]
      },
      "Password": {
        "PrecisionStep": "1",
        "InvalidEquivalenceClasses": [
          "password",
          "12345678",
          " "
        ]
      },
      "Boolean": {
        "PrecisionStep": "1",
        "InvalidEquivalenceClasses": [
          "yes",
          "1",
          "",
          "maybe"
        ]
      },
      "Integer": {
        "PrecisionStep": "1",
        "InvalidEquivalenceClasses": [
          "abc",
          "",
          "12.5",
          "999999999999999999999",
          "1e10"
        ]
      },
      "Decimal": {
        "PrecisionStep": "0.01",
        "InvalidEquivalenceClasses": [
          "NaN",
          "infinity",
          "text",
          "",
          "--5.0"
        ]
      },
      "Percentage": {
        "PrecisionStep": "0.01",
        "InvalidEquivalenceClasses": [ -1, -0.01, 100.01, 101 ]
      },
      "Currency": {
        "PrecisionStep": "0.01",
        "FormatString": "C2",
        "InvalidEquivalenceClasses": [ -5, -0.01, "free", "" ]
      },
      "Date": {
        "PrecisionStep": "1",
        "PrecisionStepUnit": "Days",
        "FormatString": "yyyy-MM-dd",
        "InvalidEquivalenceClasses": [
          "not-a-date",
          "13/32/2020",
          "2023-02-29",
          "0000-00-00"
        ]
      },
      "Time": {
        "PrecisionStep": "15",
        "PrecisionStepUnit": "Minutes",
        "FormatString": "hh\\:mm",
        "InvalidEquivalenceClasses": [ "24:00", "99:99", "noon", "-01:00" ]
      },
      "DateTime": {
        "PrecisionStep": "1",
        "PrecisionStepUnit": "Minutes",
        "FormatString": "yyyy-MM-ddTHH:mm:ss",
        "InvalidEquivalenceClasses": [
          "tomorrow",
          "32/01/2022 25:00",
          "2023-02-29T12:00:00"
        ]
      },
      "Week": {
        "PrecisionStep": "1",
        "FormatString": "yyyy-'W'ww",
        "InvalidEquivalenceClasses": [ "2025-W60", "2024-W00", "not-a-week" ]
      },
      "Month": {
        "PrecisionStep": "1",
        "FormatString": "yyyy-MM",
        "InvalidEquivalenceClasses": [ "2025-13", "2025-00", "March 2025" ]
      },
      "Address": {
        "PrecisionStep": "1",
        "InvalidEquivalenceClasses": [ "", "ZZZ" ]
      },
      "GeoCoordinate": {
        "PrecisionStep": "0.01",
        "FormatString": "F6",
        "InvalidEquivalenceClasses": [
          "NaN,NaN",
          "91.0000,0.0000",
          "0.0000,181.0000",
          "text"
        ]
      },
      "Username": {
        "PrecisionStep": "1",
        "InvalidEquivalenceClasses": [
          "admin!",
          "root$",
          "<script>",
          "a"
        ]
      },
      "URL": {
        "PrecisionStep": "5",
        "InvalidEquivalenceClasses": [
          "www.google.com",
          "ftp://wrong.protocol",
          "://missing.scheme.com",
          "javascript:alert(1)"
        ]
      },
      "Color": {
        "InvalidEquivalenceClasses": [
          "FF0000",
          "#GGGGGG",
          "#12345",
          "red"
        ]
      }
    }
  }
}
