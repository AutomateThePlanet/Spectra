{
  "source": {
    "mode": "local",
    "local_dir": "docs/",
    "max_file_size_kb": 50,
    "include_patterns": ["**/*.md"],
    "exclude_patterns": ["**/CHANGELOG.md"]
  },
  "tests": {
    "dir": "tests/",
    "id_prefix": "TC",
    "id_start": 100
  },
  "ai": {
    "providers": [
      {
        "name": "github-models",
        "model": "gpt-4o",
        "enabled": true,
        "priority": 1
      },
      {
        "name": "openai",
        "model": "gpt-4o",
        "enabled": false,
        "priority": 2,
        "api_key_env": "OPENAI_API_KEY"
      },
      {
        "name": "anthropic",
        "model": "claude-sonnet-4-5-20250514",
        "enabled": false,
        "priority": 3,
        "api_key_env": "ANTHROPIC_API_KEY"
      }
    ],
    "fallback_strategy": "auto"
  },
  "generation": {
    "default_count": 15,
    "require_review": true,
    "duplicate_threshold": 0.6,
    "categories": ["happy_path", "negative", "boundary", "integration"]
  },
  "validation": {
    "required_fields": ["id", "priority"],
    "allowed_priorities": ["high", "medium", "low"],
    "max_steps": 20,
    "id_pattern": "^TC-\\d{3,}$"
  },
  "dashboard": {
    "output_dir": "./site",
    "include_coverage": true,
    "include_runs": true,
    "max_trend_points": 30,
    "cloudflare_project_name": "spectra-dashboard"
  },
  "git": {
    "auto_branch": true,
    "branch_prefix": "spectra/",
    "auto_commit": true,
    "auto_pr": false
  }
}
