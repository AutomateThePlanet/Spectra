{
  "source": {
    "mode": "local",
    "local_dir": "docs/",
    "max_file_size_kb": 50,
    "include_patterns": ["**/*.md"],
    "exclude_patterns": ["**/CHANGELOG.md"]
  },
  "tests": {
    "dir": "tests/",
    "id_prefix": "TC",
    "id_start": 100
  },
  "ai": {
    "providers": [
      {
        "name": "github-models",
        "model": "gpt-4.1",
        "enabled": true,
        "priority": 1
      },
      {
        "name": "openai",
        "model": "gpt-4.1",
        "enabled": false,
        "priority": 2,
        "api_key_env": "OPENAI_API_KEY"
      },
      {
        "name": "anthropic",
        "model": "claude-sonnet-4-5",
        "enabled": false,
        "priority": 3,
        "api_key_env": "ANTHROPIC_API_KEY"
      }
    ],
    "fallback_strategy": "auto",
    "critic": {
      "enabled": true,
      "provider": "github-models",
      "model": "gpt-5-mini"
    }
  },
  "generation": {
    "default_count": 15,
    "require_review": true,
    "duplicate_threshold": 0.6,
    "categories": ["happy_path", "negative", "boundary", "integration"]
  },
  "validation": {
    "required_fields": ["id", "priority"],
    "allowed_priorities": ["high", "medium", "low"],
    "max_steps": 20,
    "id_pattern": "^TC-\\d{3,}$"
  },
  "dashboard": {
    "output_dir": "./site",
    "include_coverage": true,
    "include_runs": true,
    "max_trend_points": 30,
    "cloudflare_project_name": "spectra-dashboard",
    "branding": {
      "company_name": "SPECTRA",
      "logo": "assets/spectra-logo.svg",
      "favicon": "assets/favicon.ico",
      "theme": "light",
      "_comment_theme": "Options: 'light' or 'dark'",
      "colors": {
        "primary": null,
        "accent": null,
        "_comment_colors": "Override theme colors: primary, accent, background, text, surface, border. Use CSS color values (#hex, rgb(), hsl(), named)."
      },
      "custom_css": null,
      "_comment_custom_css": "Path to a custom CSS file loaded after default styles for full override control."
    }
  },
  "execution": {
    "copilot_space": null,
    "copilot_space_owner": null
  },
  "bug_tracking": {
    "provider": "auto",
    "template": "templates/bug-report.md",
    "default_severity": "medium",
    "auto_attach_screenshots": true,
    "auto_prompt_on_failure": true
  },
  "git": {
    "auto_branch": true,
    "branch_prefix": "spectra/",
    "auto_commit": true,
    "auto_pr": false
  },
  "testimize": {
    "enabled": false,
    "_comment": "Optional integration with Testimize.MCP.Server for algorithmic test data optimization (BVA, EP, pairwise, ABC). Install with: dotnet tool install --global Testimize.MCP.Server",
    "mode": "exploratory",
    "strategy": "HybridArtificialBeeColony",
    "mcp": {
      "command": "testimize-mcp",
      "args": ["--mcp"]
    }
  },
  "debug": {
    "enabled": false,
    "_comment": "Spec 040: opt-in .spectra-debug.log. Set enabled=true to persist per-call AI diagnostics, or run any AI command with --verbosity diagnostic to force-enable for a single run.",
    "log_file": ".spectra-debug.log",
    "mode": "append",
    "_comment_mode": "append (default): keep existing log content and add a separator + header before each new run. overwrite: truncate the file at run start, keeping only the latest run."
  }
}
