{
  "source": {
    "mode": "local",
    "local_dir": "docs/",
    "max_file_size_kb": 50,
    "include_patterns": [
      "**/*.md"
    ],
    "exclude_patterns": [
      "**/CHANGELOG.md"
    ]
  },
  "tests": {
    "dir": "tests/",
    "id_prefix": "TC",
    "id_start": 100
  },
  "ai": {
    "providers": [
      {
        "name": "azure-anthropic",
        "model": "claude-sonnet-4-5",
        "enabled": true,
        "priority": 1,
        "api_key_env": "AZURE_ANTHROPIC_API_KEY",
        "base_url": "https://angel-mdnhzlaw-swedencentral.services.ai.azure.com/"
      }
    ],
    "fallback_strategy": "auto"
  },
  "generation": {
    "default_count": 15,
    "require_review": true,
    "duplicate_threshold": 0.6,
    "categories": [
      "happy_path",
      "negative",
      "boundary",
      "integration"
    ]
  },
  "update": {
    "chunk_size": 30,
    "require_review": true
  },
  "suites": {},
  "git": {
    "auto_branch": true,
    "branch_prefix": "spectra/",
    "auto_commit": true,
    "auto_pr": false
  },
  "validation": {
    "required_fields": [
      "id",
      "priority"
    ],
    "allowed_priorities": [
      "high",
      "medium",
      "low"
    ],
    "max_steps": 20,
    "id_pattern": "^TC-\\d{3,}$"
  },
  "dashboard": {
    "output_dir": "./site",
    "include_coverage": true,
    "include_runs": true,
    "max_trend_points": 30
  },
  "coverage": {
    "automation_dirs": [
      "tests",
      "test",
      "spec",
      "specs",
      "e2e"
    ],
    "file_patterns": [
      "*.cs",
      "*.ts",
      "*.js",
      "*.py",
      "*.java"
    ],
    "attribute_patterns": [
      "\\[(?:TestCase|Theory|Fact|Test)\\s*\\(\\s*\u0022(TC-\\d{3,})\u0022",
      "\\[InlineData\\s*\\([^)]*\u0022(TC-\\d{3,})\u0022",
      "(?://|#)\\s*(TC-\\d{3,})(?:\\s*:|$)",
      "(?:it|describe|test)\\s*\\(\\s*[\u0027\u0022](?:.*?)?(TC-\\d{3,})"
    ],
    "test_id_pattern": "TC-\\d{3,}",
    "report_orphans": true,
    "report_broken_links": true,
    "report_mismatches": true
  },
  "profile": {
    "auto_load": true,
    "validate_on_load": true,
    "include_in_validation": true
  }
}