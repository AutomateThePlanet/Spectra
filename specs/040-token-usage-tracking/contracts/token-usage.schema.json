{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectra.dev/schemas/token-usage.json",
  "title": "Spectra Token Usage Report",
  "description": "Shape of the `token_usage` field in --output-format json results and .spectra-result.json (Spec 040).",
  "type": "object",
  "required": ["phases", "total", "estimated_cost_usd"],
  "additionalProperties": false,
  "properties": {
    "phases": {
      "type": "array",
      "items": { "$ref": "#/$defs/phaseUsage" }
    },
    "total": { "$ref": "#/$defs/phaseUsage" },
    "estimated_cost_usd": {
      "type": ["number", "null"],
      "description": "USD cost estimate; null for github-models or unknown models."
    },
    "cost_display": {
      "type": "string",
      "description": "Human-readable cost message rendered in the terminal."
    }
  },
  "$defs": {
    "phaseUsage": {
      "type": "object",
      "required": ["phase", "calls", "tokens_in", "tokens_out", "total_tokens", "elapsed_seconds"],
      "additionalProperties": false,
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["analysis", "generation", "critic", "update", "criteria", "TOTAL"]
        },
        "model": { "type": "string" },
        "provider": { "type": "string" },
        "calls": { "type": "integer", "minimum": 0 },
        "tokens_in": { "type": "integer", "minimum": 0 },
        "tokens_out": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "elapsed_seconds": { "type": "number", "minimum": 0 }
      }
    }
  }
}
